# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter_kit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=starter_kit
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ─── AI provider — self-hosted Ollama ─────────────────────────────────────────
# Base URL of the self-hosted Ollama server. Point this at your own host; the
# real LAN address is kept out of git (set it in .env, not here). The value below
# is the standard local Ollama port as a placeholder.
OLLAMA_BASE_URL=http://localhost:11434
# Embedding model (768-dim). Must be pulled on the host.
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Generation model — pending the bake-off (gemma4:26b vs qwen3.6:27b-64k).
# Intentionally left unset: generation calls fail fast until a model is chosen.
# OLLAMA_GENERATION_MODEL=

# ─── Storage / S3 (optional) ──────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Admin password used by the DB seed script (packages/shared/prisma/seed.ts).
# If unset, the seed falls back to an insecure default and logs a warning.
ADMIN_PASSWORD=
